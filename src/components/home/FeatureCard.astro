---
import { Icon } from "astro-icon/components";

import type { Feature } from "@/types/types";

import FeatureCardProducts from "@/components/home/FeatureCardProducts.astro";

interface Props {
  feature: Feature;
}

const { feature } = Astro.props;
---

<article class="featureCard">
  <div class="featureCard__header">
    <FeatureCardProducts products={feature.products} />
    <span class="featureCard__mark" aria-hidden="true">
      <Icon name={feature.icon} />
    </span>
  </div>
  <h3 class="featureCard__title">{feature.title}</h3>
  <div class="featureCard__content">
    {feature.content.map((p) => <p set:html={p} />)}
  </div>
  <div class="featureCard__support">
    <div>Hello</div>
  </div>
</article>

<style lang="scss">
  .featureCard {
    position: relative;

    height: 100%;
    overflow: hidden;
    padding: var(--space-small);

    background-color: var(--grey-200);
    // border: 0.1rem solid var(--border-color);
    border-radius: var(--border-radius-m);
    box-shadow: var(--box-shadow-diffuse);

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-small);
    }

    &__mark {
      display: grid;
      place-content: center;
      height: 3.2rem;
      width: 3.2rem;

      background-color: rgba(255, 255, 255, 0.8);
      border-radius: 9999px;
      box-shadow: 0 0.2rem 0.8rem rgba(0, 0, 0, 0.12);
      color: var(--text-color-dim);

      svg {
        display: block;
        height: 1.9rem;
        width: auto;
      }
    }

    &__title {
      margin-top: 0;

      // color: white;
      font-size: 2rem;
    }

    &__content {
      color: var(--text-color-dim);
    }

    &__support {
      position: absolute;
      top: 0;
      left: var(--space-medium);
      z-index: 2;

      display: block;
      height: 100%;
      width: 100%;

      filter: drop-shadow(1rem 0 3rem rgb(0 0 0));

      transform: translateX(100%);
      transition: transform 0.3s var(--custom-easing) 0.3s;

      // > div {
      //   --border-width: 3.6rem;

